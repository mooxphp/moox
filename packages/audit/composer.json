{
    "name": "moox/audit",
    "description": "Activity logging and audit UI for Moox based on Spatie Laravel Activity Log",
    "keywords": [
        "Laravel",
        "Filament",
        "Filament plugin",
        "Laravel package",
        "audit",
        "activity log"
    ],
    "homepage": "https://moox.org/",
    "license": "MIT",
    "authors": [
        {
            "name": "Moox Developer",
            "email": "dev@moox.org",
            "role": "Developer"
        }
    ],
    "require": {
        "moox/core": "dev-main",
        "spatie/laravel-activitylog": "dev-main"
    },
    "require-dev": {
        "moox/devtools": "dev-main",
        "moox/category": "dev-main",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.7"
    },
    "autoload": {
        "psr-4": {
            "Moox\\Audit\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Moox\\Audit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Moox\\Audit\\AuditServiceProvider"
            ]
        },
        "moox": {
            "stability": "stable"
        }
    },
    "scripts": {
        "test": [
            "@php ../../vendor/bin/pest --configuration=phpunit.xml tests/Unit"
        ]
    },
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
