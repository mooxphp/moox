{
    "name": "moox/cache-static",
    "description": "Page cache targets for Moox Cache (Joseph Silber page-cache)",
    "keywords": [
        "Laravel",
        "Filament",
        "page cache",
        "static cache",
        "Laravel package"
    ],
    "homepage": "https://moox.org/",
    "license": "MIT",
    "authors": [
        {
            "name": "Moox Developer",
            "email": "dev@moox.org",
            "role": "Developer"
        }
    ],
    "require": {
        "moox/cache": "dev-main",
        "moox/core": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "Moox\\CacheStatic\\": "src"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Moox\\CacheStatic\\CacheStaticServiceProvider"
            ]
        },
        "moox": {
            "stability": "dev"
        }
    },
    "prefer-stable": true,
    "require-dev": {
        "moox/devtools": "dev-main"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
