{
    "name": "moox/page",
    "description": "Moox Page entity for creating and managing CMS pages with Filament, block editor, and translations.",
    "keywords": [
        "Moox",
        "Laravel",
        "Filament",
        "Moox package",
        "Laravel package"
    ],
    "homepage": "https://moox.org/docs/page",
    "license": "MIT",
    "authors": [
        {
            "name": "Moox Developer",
            "email": "dev@moox.org",
            "role": "Developer"
        }
    ],
    "require": {
        "moox/block-editor": "dev-main",
        "moox/core": "dev-main",
        "moox/localization": "dev-main",
        "moox/media": "dev-main",
        "moox/category": "dev-main",
        "moox/tag": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "Moox\\Page\\": "src",
            "Moox\\Page\\Database\\Factories\\": "database/factories",
            "Moox\\Page\\Database\\Seeders\\": "database/seeders"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Moox\\Page\\Tests\\": "tests/"
        },
        "files": [
            "tests/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Moox\\Page\\PageServiceProvider"
            ]
        },
        "moox": {
            "name": "Moox Page",
            "stability": "stable",
            "type": "moox-plugin",
            "install": {
                "auto_migrate": "database/migrations",
                "seed": "database/seeders/PageSeeder.php",
                "auto_publish": "moox-page-config",
                "auto_entities": {
                    "Page": true
                },
                "auto_class": {
                    "Page": "Moox\\Page\\Models\\Page"
                }
            },
            "update": {
                "migrate": "database/migrations",
                "merge": "moox-page-config"
            },
            "uninstall": {
                "migrate": "database/migrations",
                "remove": "moox-page-config"
            }
        }
    },
    "prefer-stable": true,
    "require-dev": {
        "moox/devtools": "dev-main",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-livewire": "^4.0"
    },
    "scripts": {
        "test": [
            "@php ../../../vendor/bin/pest --configuration=phpunit.xml.dist tests/Unit tests/Feature"
        ],
        "test:arch": [
            "@php ../../../vendor/bin/pest --configuration=phpunit.xml.dist --bootstrap=tests/bootstrap-arch.php tests/ArchTest.php"
        ]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
