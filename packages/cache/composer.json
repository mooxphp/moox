{
    "name": "moox/cache",
    "description": "Filament cache manager with extensible cache targets for Laravel and Moox",
    "keywords": [
        "Laravel",
        "Filament",
        "Filament plugin",
        "cache",
        "Laravel package"
    ],
    "homepage": "https://moox.org/",
    "license": "MIT",
    "authors": [
        {
            "name": "Moox Developer",
            "email": "dev@moox.org",
            "role": "Developer"
        }
    ],
    "require": {
        "moox/core": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "Moox\\Cache\\": "src"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Moox\\Cache\\CacheServiceProvider"
            ]
        },
        "moox": {
            "stability": "dev"
        }
    },
    "prefer-stable": true,
    "require-dev": {
        "moox/devtools": "dev-main"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
