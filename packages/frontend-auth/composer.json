{
    "name": "moox/frontend-auth",
    "description": "Moox Frontend Auth - Protects frontend routes via Filament login.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Moox",
            "email": "dev@moox.org"
        }
    ],
    "require": {
        "php": "^8.2",
        "moox/core": "*",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.15"
    },
    "autoload": {
        "psr-4": {
            "Moox\\FrontendAuth\\": "src"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Moox\\FrontendAuth\\FrontendAuthServiceProvider"
            ]
        },
        "moox-stability": "dev"
    },
    "config": {
        "sort-packages": true
    }
}

