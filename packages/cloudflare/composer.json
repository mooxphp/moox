{
    "name": "moox/cloudflare",
    "description": "Cloudflare cache purge targets and API client for Moox Cache",
    "keywords": [
        "Laravel",
        "Filament",
        "Cloudflare",
        "cache purge",
        "Laravel package"
    ],
    "homepage": "https://moox.org/",
    "license": "MIT",
    "authors": [
        {
            "name": "Moox Developer",
            "email": "dev@moox.org",
            "role": "Developer"
        }
    ],
    "require": {
        "guzzlehttp/guzzle": "^7.0|^8.0",
        "moox/cache": "dev-main",
        "moox/core": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "Moox\\Cloudflare\\": "src"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Moox\\Cloudflare\\CloudflareServiceProvider"
            ]
        },
        "moox": {
            "stability": "dev"
        }
    },
    "prefer-stable": true,
    "require-dev": {
        "moox/devtools": "dev-main"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
