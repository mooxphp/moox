{
    "name": "moox/tree",
    "description": "moox Tree adds a tree view to your hierarchical Filament resources.",
    "type": "library",
    "license": "MIT",
    "require": {
        "moox/core": "dev-main"
    },
    "suggest": {
        "kalnoy/nestedset": "Required for nested set tree indexes (^6.0)"
    },
    "autoload": {
        "psr-4": {
            "Heco\\FilamentTreeIndex\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Heco\\FilamentTreeIndex\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Heco\\FilamentTreeIndex\\FilamentTreeIndexServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}