{
    "name": "heco/filament-tree-index",
    "description": "Filament resource tree index UI for hierarchical Eloquent models.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "filament/filament": "^5.0",
        "laravel/framework": "^12.0",
        "livewire/livewire": "^4.0"
    },
    "suggest": {
        "kalnoy/nestedset": "Required for nested set tree indexes (^6.0)"
    },
    "autoload": {
        "psr-4": {
            "Heco\\FilamentTreeIndex\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Heco\\FilamentTreeIndex\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Heco\\FilamentTreeIndex\\FilamentTreeIndexServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
