{
    "name": "moox/permission",
    "description": "Moox layer for Filament Shield and shared authorization defaults.",
    "keywords": [
        "Laravel",
        "Filament",
        "permissions",
        "roles",
        "shield"
    ],
    "homepage": "https://moox.org/",
    "license": "MIT",
    "authors": [
        {
            "name": "Moox Developer",
            "email": "dev@moox.org",
            "role": "Developer"
        }
    ],
    "require": {
        "moox/core": "dev-main",
        "bezhansalleh/filament-shield": "^4.0"
    },
    "require-dev": {
        "moox/devtools": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "Moox\\Permission\\": "src"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Moox\\Permission\\PermissionServiceProvider"
            ]
        },
        "moox": {
            "stability": "stable",
            "install": {
                "plugins": [
                    "BezhanSalleh\\FilamentShield\\FilamentShieldPlugin"
                ]
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
