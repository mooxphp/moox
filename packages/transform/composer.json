{
    "name": "moox/transform",
    "description": "Lightweight transformation pipeline with validation and traceability for Laravel models.",
    "keywords": [
        "Laravel",
        "Filament",
        "Laravel package"
    ],
    "homepage": "https://moox.org/",
    "license": "MIT",
    "authors": [
        {
            "name": "Moox Developer",
            "email": "dev@moox.org",
            "role": "Developer"
        }
    ],
    "require": {
        "moox/core": "*"
    },
    "autoload": {
        "psr-4": {
            "Moox\\Transform\\": "src"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Moox\\Transform\\TransformServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^3.2",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Moox\\Transform\\Tests\\": "tests"
        }
    }
}
