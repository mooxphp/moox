{
    "name": "moox/kosit-validator",
    "description": "KoSIT Validator CLI wrapper and Filament extension for ZUGFeRD / XRechnung XML validation against EN 16931.",
    "keywords": [
        "Moox",
        "Laravel",
        "Filament",
        "Moox package",
        "Laravel package"
    ],
    "homepage": "https://moox.org/docs/kosit-validator",
    "license": "MIT",
    "authors": [
        {
            "name": "Moox Developer",
            "email": "dev@moox.org",
            "role": "Developer"
        }
    ],
    "require": {
        "moox/core": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "Moox\\KositValidator\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Moox\\KositValidator\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Moox\\KositValidator\\KositValidatorServiceProvider"
            ]
        },
        "moox": {
            "stability": "dev"
        }
    },
    "prefer-stable": true,
    "require-dev": {
        "moox/devtools": "dev-main"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}