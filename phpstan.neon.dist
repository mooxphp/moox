includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 5
    ignoreErrors:
        -
            message: "#^Called 'env' outside of the config directory#"
            paths:
                - packages/*/config/*
    paths:
        - packages
    excludePaths:
        - 'packages/*/vendor/*'
        - 'packages/*/wordpress/*'
        - 'packages/*/tests/*'
    tmpDir: build/phpstan