includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 5
    ignoreErrors:
        -
            message: "#^Called 'env' outside of the config directory#"
            paths:
                - packages/*/config/*
    paths:
        - packages
    excludePaths:
        - 'packages/*/vendor/*'
        - 'packages/*/wordpress/*'
        - 'packages/*/tests/*'
        - 'packages/core/src/Traits/Publish/*.php'
        - 'packages/core/src/Traits/Simple/*.php'
        - 'packages/core/src/Traits/Base/BaseInCreatePage.php'
        - 'packages/core/src/Traits/Base/BaseInEditPage.php'
        - 'packages/core/src/Traits/Base/BaseInViewPage.php'
        - 'packages/core/src/Traits/HasScheduledPublish.php'
        - 'packages/core/src/Traits/SoftDelete/SingleSoftDeleteInCreatePage.php'
        - 'packages/core/src/Traits/SoftDelete/SingleSoftDeleteInEditPage.php'
        - 'packages/core/src/Traits/SoftDelete/SingleSoftDeleteInViewPage.php'
    tmpDir: build/phpstan